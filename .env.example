# H.A.W.L.E. / Hawley local configuration

# Postgres
PGHOST=localhost
PGPORT=5432
PGDATABASE=bowlus_ops
PGUSER=bowlus_app
PGPASSWORD=
DATABASE_URL=postgres://bowlus_app:CHANGE_ME@localhost:5432/bowlus_ops

# Source-system credentials. Store values only in local .env files.
AIRTABLE_PAT=
AIRTABLE_BASE=
ASANA_PAT=

# Safety defaults
HAWLEY_DRY_RUN=true
HAWLEY_ALLOW_SOURCE_WRITES=false
