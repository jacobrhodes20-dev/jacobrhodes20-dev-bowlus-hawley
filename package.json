{
  "name": "bowlus-hawley",
  "private": true,
  "version": "0.1.0",
  "description": "H.A.W.L.E. - Historical Asana/Airtable Workflow Layer for Engineering.",
  "type": "module",
  "scripts": {
    "pg:health": "node ./apps/postgres-sync/src/health.js",
    "pg:migrate": "node ./apps/postgres-sync/src/migrate.js",
    "pg:pull:airtable": "node ./apps/postgres-sync/src/pull-airtable.js",
    "pg:pull:asana": "node ./apps/postgres-sync/src/pull-asana.js",
    "pg:normalize": "node ./apps/postgres-sync/src/normalize-airtable.js",
    "pg:load:ops-hints": "node ./apps/postgres-sync/src/load-ops-owner-hints.js",
    "pg:sync:dry": "npm run pg:pull:airtable && npm run pg:normalize",
    "pg:summary": "node ./apps/postgres-sync/src/import-summary.js",
    "worker:hawley": "node ./apps/hawley-worker-page/server.js"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "pg": "^8.13.1"
  }
}
